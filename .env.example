POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=user
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
POSTGRES_HOST=db

POSTGRES_URL=postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DB?sslmode=$POSTGRES_SSLMODE

SIGNING_KEY=password

MAX_AUDIO_SIZE=52428800
MAX_VIDEO_SIZE=104857600

S3_URL=http://localhost:3900
S3_BUCKET_NAME=my-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=access_key_id
S3_SECRET_ACCESS_KEY=secret_access_key
S3_PRESIGN_EXPIRATION_SECONDS=300
